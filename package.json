{
  "name": "empireai",
  "version": "0.1.0",
  "private": true,
  "description": "EmpireAI monorepo — run setup from repository root",
  "scripts": {
    "setup": "npm run setup --prefix backend",
    "setup:all": "npm run setup --prefix backend && npm install --prefix empireai-web",
    "verify:env": "npm run verify:env --prefix backend",
    "architect:report": "npm run architect:report --prefix backend",
    "empire:review": "npm run empire:review --prefix backend",
    "empire:review:fast": "npm run empire:review:fast --prefix backend",
    "validate:full": "npm run validate:full --prefix backend",
    "dev:brain": "npm run dev --prefix backend",
    "dev:web": "npm run dev --prefix empireai-web",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "build:cockpit": "npm run build --prefix empireai-web",
    "build:production": "npm run build --prefix pillow && npm run build --prefix backend && npm run build --prefix empireai-web",
    "verify:production-deploy": "node backend/scripts/verify-production-deploy.mjs",
    "verify:production-deploy:build": "node backend/scripts/verify-production-deploy.mjs --build-only",
    "vercel-build": "npm run build",
    "pillow:bootstrap": "npm run bootstrap --prefix pillow",
    "pillow:intelligence": "npm run intelligence --prefix pillow",
    "pillow:context": "npm run context --prefix pillow",
    "pillow:memory": "npm run memory --prefix pillow",
    "pillow:planner": "npm run planner --prefix pillow",
    "pillow:supervisor": "npm run supervisor --prefix pillow",
    "pillow:recovery": "npm run recovery --prefix pillow",
    "pillow:audit-reviewer": "npm run audit-reviewer --prefix pillow",
    "pillow:synchronizer": "npm run synchronizer --prefix pillow",
    "pillow:due-diligence": "npm run due-diligence --prefix pillow",
    "pillow:test": "npm run test --prefix pillow",
    "pillow:typecheck": "npm run typecheck --prefix pillow"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@vercel/node": "^5.3.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  }
}
