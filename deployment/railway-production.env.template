# EmpireAI Brain — Railway production variables (REAL-068)
# Import via Railway → Service → Variables → RAW Editor
# Replace placeholder values. Do NOT commit secrets to git.

# ── Required for autonomous operation ────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=4000

# Monorepo root inside Railway container (also set in nixpacks.toml)
EMPIREAI_REPO_ROOT=/app

# SQLite on attached volume (also set in nixpacks.toml)
DATABASE_PATH=/data/empireai-brain.db

# Upstash Redis — use rediss:// TLS URL from Upstash console
REDIS_URL=rediss://default:REPLACE@REPLACE.upstash.io:6379

# Must match deployed frontend origin exactly (Vercel production URL)
CORS_ORIGIN=https://REPLACE-YOUR-FRONTEND.vercel.app

# 32+ random characters — rotate from dev default
SESSION_SECRET=REPLACE-WITH-LONG-RANDOM-SECRET

# At least one LLM provider (gemini alias supported — maps to GOOGLE_AI_API_KEY)
OPENAI_API_KEY=sk-REPLACE
# ANTHROPIC_API_KEY=sk-ant-REPLACE
# GEMINI_API_KEY=REPLACE
# GOOGLE_AI_API_KEY=REPLACE

DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Live payments (Mission 103 / revenue loop)
STRIPE_SECRET_KEY=sk_live_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE
# STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE

GUARDIAN_ENABLED=true

# ── Do NOT set in production ─────────────────────────────────────────────────
# REDIS_OPTIONAL=true
# VERCEL=1
