# EmpireAI Brain — Backend Environment

# ── Managed cloud (V1 production) ───────────────────────────────────────────
# Frontend: Vercel — set VITE_API_BASE_URL to this service's public URL
# Backend:  Railway — deploy from repo root (see railway.toml)
# Redis:    Upstash — use rediss:// TLS URL
# Database: SQLite on Railway volume — DATABASE_PATH=/data/empireai-brain.db
#           Supabase Postgres is post-V1 (ADR-002); see deployment/supabase.md
# CORS_ORIGIN must match Vercel frontend origin exactly
# EMPIREAI_REPO_ROOT=/app (monorepo root for Pillow bootstrap)

# Redis (required in production on Railway; optional in development)
REDIS_URL=redis://127.0.0.1:6379
# Production Upstash example:
# REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379
# NODE_ENV=development
# REDIS_OPTIONAL=true

# SQLite database path for audit logs, memory, and users
DATABASE_PATH=./data/empireai-brain.db

# LLM provider API keys (configure providers you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Default LLM routing
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# Session security (change in production)
SESSION_SECRET=empireai-dev-session-secret-change-in-production-min-32-chars
SESSION_TTL_SECONDS=604800

# Default seeded users (dev only — override in production)
FOUNDER_EMAIL=founder@empireai.com
FOUNDER_PASSWORD=EmpireAI2026!
ADMIN_EMAIL=admin@empireai.com
ADMIN_PASSWORD=EmpireAI2026!

# Guardian Engine (blocks unsafe dispatches, monitors subsystem health)
GUARDIAN_ENABLED=true

# CJ Dropshipping (Mission 074 — supplier integration)
# CJ_INTEGRATION_MODE=SANDBOX
# CJ_INTEGRATION_MODE=LIVE
CJ_API_KEY=
CJ_API_SECRET=
# CJ_API_BASE_URL=https://developers.cjdropshipping.com/api2.0/v1
# CJ_REQUEST_TIMEOUT_MS=15000
# CJ_MAX_RETRIES=3
# CJ_RATE_LIMIT_PER_MINUTE=60

# Mission 101 — Minimum Live Revenue Loop
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=
# REVENUE_LOOP_STORE_BASE_URL=http://localhost:4000
# REVENUE_LOOP_DEPLOY_ROOT=./data/deployed-stores
# REVENUE_LOOP_LIVE_FULFILLMENT_ENABLED=false
# REVENUE_LOOP_MIN_PROFIT_CENTS=100
# REVENUE_LOOP_MOCK_PAYMENTS=true
# REVENUE_LOOP_GA4_ID=
# REVENUE_LOOP_META_PIXEL_ID=
# REVENUE_LOOP_TIKTOK_PIXEL_ID=

# Mission 102 — Production Store Deployment (Vercel)
# VERCEL_API_TOKEN=
# VERCEL_TEAM_ID=
# PRODUCTION_DEPLOYMENT_ENABLED=false
# PRODUCTION_DEPLOY_ROOT=./data/production-deployments
# PRODUCTION_DEPLOY_MOCK=true

# Mission 103 — Live Payment Engine
# LIVE_PAYMENT_ENABLED=false
# LIVE_PAYMENT_MOCK=true
# LIVE_PAYMENT_STORE_BASE_URL=http://localhost:4000
# Uses STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_PUBLISHABLE_KEY from above

# Mission 104 — Customer Order Pipeline
# CUSTOMER_ORDER_PIPELINE_LIVE_FULFILLMENT_ENABLED=false
# CUSTOMER_ORDER_PIPELINE_DEFAULT_INVENTORY_UNITS=100
# CUSTOMER_ORDER_PIPELINE_SHIPPING_ESTIMATE_CENTS=599
# CUSTOMER_ORDER_PIPELINE_AUTO_SANDBOX_TRACKING=true

# Mission 105 — LIVE CJ Fulfillment
# LIVE_CJ_FULFILLMENT_ENABLED=false
# LIVE_CJ_FULFILLMENT_MOCK=true
# LIVE_CJ_FULFILLMENT_MAX_RETRY_ATTEMPTS=3
# CJ_INTEGRATION_MODE=LIVE
# CJ_API_KEY=
# CJ_API_SECRET=

# Mission 106 — Analytics & Conversion Engine
# ANALYTICS_CONVERSION_ENABLED=true
# ANALYTICS_SERVER_SIDE_MOCK=true
# GA4_MEASUREMENT_ID=
# GA4_API_SECRET=
# META_PIXEL_ID=
# META_CONVERSIONS_ACCESS_TOKEN=
# TIKTOK_PIXEL_ID=
# TIKTOK_ACCESS_TOKEN=

# Mission 107 — Meta Ads Connector
# META_ADS_APP_ID=
# META_ADS_APP_SECRET=
# META_ADS_REDIRECT_URI=http://localhost:4000/meta-ads/oauth/callback
# META_ADS_ACCESS_TOKEN=
# META_ADS_AD_ACCOUNT_ID=
# META_ADS_LAUNCH_ENABLED=false
# META_ADS_MOCK=true
# META_ADS_GRAPH_VERSION=v19.0

# Mission 108 — Product Publishing Engine
# PRODUCT_PUBLISHING_ENABLED=true
# PRODUCT_PUBLISHING_LIVE_SUPPLIER_SYNC=false
# PRODUCT_PUBLISHING_MOCK=true
# PRODUCT_PUBLISHING_LOW_STOCK_THRESHOLD=5
# PRODUCT_PUBLISHING_DEFAULT_MARKUP=2.2

# Mission 109 — Grand King's Revenue Engine
# GRAND_KINGS_REVENUE_ENGINE_ENABLED=true
# GRAND_KINGS_REVENUE_ENGINE_MOCK=false

# Mission 110 — First Revenue Validation
# FIRST_REVENUE_VALIDATION_ENABLED=true
# FIRST_REVENUE_VALIDATION_MOCK=true

# Version 1 Operational Activation (M1–M5)
# Set LIVE_COMMERCE_INTEGRATION_MODE=production for live commerce paths
LIVE_COMMERCE_INTEGRATION_MODE=sandbox
CREDENTIAL_VAULT_KEY=
# Amazon SP-API (production marketplace — M2/M3)
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_SP_API_REFRESH_TOKEN=
# CJ Dropshipping — alternate names CJ_API_KEY / CJ_API_SECRET also supported
# CJ_DROPSHIPPING_API_KEY=
# CJ_DROPSHIPPING_API_SECRET=
# M5 — enable Pillow production mode only after operational validation
# EMPIRE_V1_OPERATIONAL_READY=false
